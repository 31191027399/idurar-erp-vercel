# MongoDB Atlas Connection String (Required)
# Get from MongoDB Atlas: Connect > Connect your application > Node.js
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/idurar?retryWrites=true&w=majority

# Application Settings
PORT=8888
NODE_ENV=production

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# OpenAI API Key (Optional - for AI features)
OPENAI_API_KEY=

# Email Settings (Optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Storage (Optional - Local or S3)
FILE_STORAGE=local
# For S3 Storage:
# FILE_STORAGE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# Resend API Key (Optional - for email via Resend)
RESEND_API_KEY=

# Frontend URL (for CORS and email links)
FRONTEND_URL=https://your-app.vercel.app
